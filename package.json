    "model-context-protocol",
    "mcp-server",
    "x402",
    "ai-agents",
    "agentic",
    "agent-tools",
    "micropayments",
    "usdc",
    "base",
    "provenance",
    "content-provenance",
    "quality-scoring",
    "audit",
    "accountability",
    "ed25519",
    "signed-receipts",
    "cloudflare-workers"
  ],
  "mcpName": "io.github.Gareth1953/agent-services-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gareth1953/agent-services-mcp.git"
  },
  "bin": { "agent-services-mcp": "dist/index.js" },
  "files": ["dist", "README.md"],
  "scripts": {
