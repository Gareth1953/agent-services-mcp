# Copy to `.env` for local development (gitignored). No secrets belong here —
# these are just the base URLs of the two underlying services.
#
# Defaults point at local `wrangler dev` servers. Note: both services default to
# port 8787, so run quality-gate on a different port to avoid a clash, e.g.:
#   (provenance-receipts) npm run dev            # http://localhost:8787
#   (quality-gate)        npx wrangler dev --port 8788

PROVENANCE_URL=http://localhost:8787
QUALITY_GATE_URL=http://localhost:8788
